# Environment variables for GovPreneurs Auto-Proposal
# Copy this file to .env and fill in your values

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://govpro:govpro_pass@localhost:5432/govpreneurs
DATABASE_URL_SYNC=postgresql://govpro:govpro_pass@localhost:5432/govpreneurs

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── SAM.gov ──────────────────────────────────────────────
# Get your API key at https://sam.gov/content/government-api-key
SAMGOV_API_KEY=your_samgov_api_key_here

# ─── AI Provider ──────────────────────────────────────────
# Options: "openai" or "gemini"
AI_PROVIDER=openai

# OpenAI (if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4o

# Gemini (if AI_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-key-here

# ─── Application ──────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
SECRET_KEY=change-this-to-a-secure-random-string-in-production

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
